{
  "name": "dsa-self-prepare",
  "private": true,
  "version": "0.1.0",
  "main": "electron/main.js",
  "description": "AI powered DSA preparation application",
  "author": "Aditya Kumar Behera",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "build:ui": "vite build",
    "build:electron": "electron-builder",
    "build": "npm run build:ui && npm run build:electron"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@monaco-editor/react": "^4.7.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "crypto": "^1.0.1",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.19",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "openai": "^6.16.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-is": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "rehype-prism-plus": "^2.0.2",
    "remark-gfm": "^4.0.1",
    "strip-ansi": "^7.1.2",
    "systeminformation": "^5.30.6",
    "uuid": "^13.0.0",
    "win-ca": "^3.5.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "wait-on": "^9.0.3"
  }
}
