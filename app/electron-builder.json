{
  "appId": "com.dsa.selfprepare",
  "productName": "DSA Self Prepare",
  "copyright": "© 2026 DSA Self Prepare",

  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "asarUnpack": [
    "electron/resources/ai/**",
    "electron/resources/runtime/**"
  ],

  "extraResources": [
    {
      "from": "app/electron/resources/ai",
      "to": "ai"
    },
    {
      "from": "app/electron/resources/runtime",
      "to": "runtime"
    }
  ],

  "files": [
    "dist/**/*",
    "electron/**/*",
    "public/**/*"
  ],

  "asar": true,

  "win": {
    "target": "nsis",
    "icon": "build/icon.ico"
  },

  "nsis": {
    "oneClick": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,

    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/uninstall.ico",
    "installerHeaderIcon": "build/icon.ico",
    "installerHeader": "build/installerHeader.bmp",
    "installerSidebar": "build/installerSidebar.bmp",

    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "DSA Self Prepare",

    "runAfterFinish": true,
    "deleteAppDataOnUninstall": true,

    "include": "build/installer.nsh"
  }

}
